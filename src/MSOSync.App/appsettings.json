{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Node": {
    "NodeId": "",
    "GroupId": "",
    "SyncUrl": ""
  },
  "Jwt": {
    "Issuer": "msosync",
    "Audience": "msosync-dashboard",
    "AccessExpiryMinutes": 60,
    "RefreshExpiryDays": 7
  },
  "Heartbeat": {
    "IntervalSeconds": 30,
    "ProbeIntervalSeconds": 60,
    "StatusCheckIntervalSeconds": 60,
    "MissedThreshold": 3
  }
}
