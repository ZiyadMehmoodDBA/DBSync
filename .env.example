# Copy to .env and fill in values — never commit .env
MSOSYNC_NODE_ID=hub
MSOSYNC_NODE_GROUP=hub-group
MSOSYNC_SYNC_URL=http://localhost:5000

DB_SERVER=localhost,1433
DB_NAME=msosync_db
